{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(*git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tdd-police-gate.sh commit",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Bash(*git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tdd-police-gate.sh push",
            "timeout": 5
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/cleanup-stamps.sh",
            "timeout": 3
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sandbox-cmux-notify.sh notification",
            "timeout": 10
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/sandbox-cmux-notify.sh stop",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(*git commit*)",
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/tdd-review-gate.sh",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
