#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'EOF'
usage: mux <name>
       mux <index>
       mux <command>

Commands:
  <name>
  <index>
  tab <name>
  list
  persist
  restore
EOF
}

state_file_path() {
  if [ -n "${MUX_STATE_FILE:-}" ]; then
    printf '%s\n' "$MUX_STATE_FILE"
  else
    printf '%s\n' "${XDG_STATE_HOME:-$HOME/.local/state}/mux/state.json"
  fi
}

ensure_command() {
  local name="$1"
  if ! command -v "$name" >/dev/null 2>&1; then
    echo "missing required command: $name" >&2
    exit 1
  fi
}

script_path() {
  local dir
  if [ -n "${MUX_SELF_PATH:-}" ]; then
    printf '%s\n' "$MUX_SELF_PATH"
    return
  fi

  dir="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
  printf '%s/%s\n' "$dir" "$(basename -- "$0")"
}

shell_quote() {
  printf "'%s'" "$(printf '%s' "$1" | sed "s/'/'\\\\''/g")"
}

rename_cmux_tab() {
  local title="$1"
  if [ -n "${CMUX_WORKSPACE_ID:-}" ] && [ -n "${CMUX_SURFACE_ID:-}" ] && command -v cmux >/dev/null 2>&1; then
    cmux rename-tab --workspace "$CMUX_WORKSPACE_ID" --surface "$CMUX_SURFACE_ID" "$title" >/dev/null 2>&1 || true
  fi
}

is_exact_integer() {
  case "$1" in
    ""|*[!0-9]*)
      return 1
      ;;
    *)
      return 0
      ;;
  esac
}

validate_session_name() {
  local name="$1"

  if is_exact_integer "$name"; then
    echo "exact integer session names are reserved for mux list indexes" >&2
    exit 1
  fi
}

title_session() {
  local title="$1"
  case "$title" in
    "mux tab "*) printf '%s\n' "${title#mux tab }" ;;
    "mux "*) printf '%s\n' "${title#mux }" ;;
    *) return 1 ;;
  esac
}

command_string_for_title() {
  local self_path="$1"
  local title="$2"
  local session

  session="$(title_session "$title")" || return 1

  case "$title" in
    "mux tab "*)
      printf '%s tab %s' "$(shell_quote "$self_path")" "$(shell_quote "$session")"
      ;;
    "mux "*)
      printf '%s %s' "$(shell_quote "$self_path")" "$(shell_quote "$session")"
      ;;
    *)
      return 1
      ;;
  esac
}

best_effort_persist_on_launch() {
  if ! command -v cmux >/dev/null 2>&1 || ! command -v jq >/dev/null 2>&1; then
    return 0
  fi

  if ! cmd_persist >/dev/null; then
    echo "warning: mux persist failed during launch" >&2
  fi
}

open_session() {
  local name="$1"
  local title="$2"

  rename_cmux_tab "$title"
  best_effort_persist_on_launch
  exec tmux new-session -A -s "$name"
}

selection_label() {
  local index="$1"
  local label="" remainder char

  while [ "$index" -gt 0 ]; do
    remainder=$(( (index - 1) % 26 ))
    printf -v char '\\%03o' $((97 + remainder))
    char="$(printf '%b' "$char")"
    label="${char}${label}"
    index=$(( (index - 1) / 26 ))
  done

  printf '%s\n' "$label"
}

find_entry_by_selector() {
  local target="$1"
  local entries entry normalized_target
  local index=0 label

  entries="$(live_mux_entries)"
  normalized_target="$(printf '%s' "$target" | tr '[:upper:]' '[:lower:]')"

  while IFS= read -r entry; do
    [ -n "$entry" ] || continue
    index=$((index + 1))
    label="$(selection_label "$index")"

    if { is_exact_integer "$target" && [ "$target" = "$index" ]; } || [ "$normalized_target" = "$label" ]; then
      printf '%s\n' "$entry"
      return 0
    fi
  done <<EOF
$entries
EOF

  return 1
}

live_mux_entries() {
  ensure_command jq

  if command -v cmux >/dev/null 2>&1; then
    cmux tree --all --json | jq -c '
      [
        .windows[]?.workspaces[]? as $workspace |
        $workspace.panes[]? as $pane |
        $pane.surfaces[]? |
        select(.type == "terminal" and (.title | test("^mux( tab)? .+"))) |
        {
          workspace_title: $workspace.title,
          pane_index: $pane.index,
          surface_index_in_pane: .index_in_pane,
          title: .title,
          session: (.title | capture("^mux( tab)? (?<session>.+)$").session)
        }
      ]
      | sort_by(.workspace_title, .pane_index, .surface_index_in_pane)
      | .[]
    '
    return
  fi

  state_file="$(state_file_path)"
  if [ ! -f "$state_file" ]; then
    echo "missing state file: $state_file" >&2
    echo "run: mux persist" >&2
    exit 1
  fi

  jq -c '
    [
      .workspaces[]? as $workspace |
      $workspace.entries[]? |
      {
        workspace_title: $workspace.title,
        pane_index: .pane_index,
        surface_index_in_pane: .surface_index_in_pane,
        title: .title,
        session: .session
      }
    ]
    | sort_by(.workspace_title, .pane_index, .surface_index_in_pane)
    | .[]
  ' "$state_file"
}

tmux_session_names() {
  if ! command -v tmux >/dev/null 2>&1; then
    return 0
  fi

  tmux list-sessions -F '#{session_name}' 2>/dev/null || true
}

selector_display() {
  local selector="$1"
  local session_names="$2"
  local session_name

  while IFS= read -r session_name; do
    [ -n "$session_name" ] || continue
    if [ "$session_name" = "$selector" ]; then
      printf '%s(*)\n' "$selector"
      return 0
    fi
  done <<EOF
$session_names
EOF

  printf '%s\n' "$selector"
}

cmd_list() {
  local entries index=0
  local entry workspace title session key
  local session_names index_display key_display
  local width_index width_key width_workspace width_title width_session
  local dashes_index dashes_key dashes_workspace dashes_title dashes_session
  local has_conflicts=0

  entries="$(live_mux_entries)"
  session_names="$(tmux_session_names)"

  width_index=1
  width_key=3
  width_workspace=9
  width_title=5
  width_session=7

  while IFS= read -r entry; do
    [ -n "$entry" ] || continue
    index=$((index + 1))
    key="$(selection_label "$index")"
    index_display="$(selector_display "$index" "$session_names")"
    key_display="$(selector_display "$key" "$session_names")"
    [ "$index_display" != "$index" ] && has_conflicts=1
    [ "$key_display" != "$key" ] && has_conflicts=1
    workspace="$(printf '%s\n' "$entry" | jq -r '.workspace_title')"
    title="$(printf '%s\n' "$entry" | jq -r '.title')"
    session="$(printf '%s\n' "$entry" | jq -r '.session')"
    [ "${#index_display}" -gt "$width_index" ] && width_index="${#index_display}"
    [ "${#key_display}" -gt "$width_key" ] && width_key="${#key_display}"
    [ "${#workspace}" -gt "$width_workspace" ] && width_workspace="${#workspace}"
    [ "${#title}" -gt "$width_title" ] && width_title="${#title}"
    [ "${#session}" -gt "$width_session" ] && width_session="${#session}"
  done <<EOF
$entries
EOF

  dashes_index="$(printf '%*s' "$width_index" '' | tr ' ' '-')"
  dashes_key="$(printf '%*s' "$width_key" '' | tr ' ' '-')"
  dashes_workspace="$(printf '%*s' "$width_workspace" '' | tr ' ' '-')"
  dashes_title="$(printf '%*s' "$width_title" '' | tr ' ' '-')"
  dashes_session="$(printf '%*s' "$width_session" '' | tr ' ' '-')"

  printf 'Join a session with: mux 1 or mux a\n'
  printf '%-*s  %-*s  %-*s  %-*s  %-*s\n' \
    "$width_index" "#" \
    "$width_key" "Key" \
    "$width_workspace" "Workspace" \
    "$width_title" "Title" \
    "$width_session" "Session"
  printf '%-*s  %-*s  %-*s  %-*s  %-*s\n' \
    "$width_index" "$dashes_index" \
    "$width_key" "$dashes_key" \
    "$width_workspace" "$dashes_workspace" \
    "$width_title" "$dashes_title" \
    "$width_session" "$dashes_session"

  index=0
  while IFS= read -r entry; do
    [ -n "$entry" ] || continue
    index=$((index + 1))
    key="$(selection_label "$index")"
    index_display="$(selector_display "$index" "$session_names")"
    key_display="$(selector_display "$key" "$session_names")"
    workspace="$(printf '%s\n' "$entry" | jq -r '.workspace_title')"
    title="$(printf '%s\n' "$entry" | jq -r '.title')"
    session="$(printf '%s\n' "$entry" | jq -r '.session')"
    printf '%-*s  %-*s  %-*s  %-*s  %-*s\n' \
      "$width_index" "$index_display" \
      "$width_key" "$key_display" \
      "$width_workspace" "$workspace" \
      "$width_title" "$title" \
      "$width_session" "$session"
  done <<EOF
$entries
EOF

  if [ "$has_conflicts" -eq 1 ]; then
    printf '(*) selector conflicts with an existing tmux session name\n'
  fi
  printf 'Tip: use mux 1 or mux a to join a listed session\n'
}

cmd_tab() {
  local name="${1:-}"
  if [ -z "$name" ]; then
    echo "mux tab requires a session name" >&2
    exit 1
  fi

  open_session "$name" "mux tab $name"
}

cmd_name() {
  local name="${1:-}"
  local entry session title
  if [ -z "$name" ]; then
    echo "mux requires a session name" >&2
    exit 1
  fi

  if entry="$(find_entry_by_selector "$name")"; then
    session="$(printf '%s\n' "$entry" | jq -r '.session')"
    title="$(printf '%s\n' "$entry" | jq -r '.title')"
    open_session "$session" "$title"
  fi

  open_session "$name" "mux $name"
}

cmd_persist() {
  local state_file temp_file

  ensure_command cmux
  ensure_command jq

  state_file="$(state_file_path)"
  mkdir -p "$(dirname "$state_file")"
  temp_file="$(mktemp "${TMPDIR:-/tmp}/mux-state.XXXXXX")"

  cmux tree --all --json | jq '
    {
      version: 1,
      workspaces: [
        .windows[]?.workspaces[]? as $workspace |
        {
          title: $workspace.title,
          entries: [
            $workspace.panes[]? as $pane |
            $pane.surfaces[]? |
            select(.type == "terminal" and (.title | test("^mux( tab)? .+"))) |
            {
              title: .title,
              session: (.title | capture("^mux( tab)? (?<session>.+)$").session),
              pane_index: $pane.index,
              surface_index_in_pane: .index_in_pane
            }
          ]
        }
      ]
    }
  ' >"$temp_file"

  mv "$temp_file" "$state_file"
  printf 'persisted %s\n' "$state_file"
}

cmd_restore() {
  local state_file current_tree self_path workspace_json workspace_title workspace_ref
  local entry_json pane_index surface_index session title surface_ref command_string

  ensure_command cmux
  ensure_command jq

  state_file="$(state_file_path)"
  if [ ! -f "$state_file" ]; then
    echo "missing state file: $state_file" >&2
    echo "run: mux persist" >&2
    exit 1
  fi

  current_tree="$(cmux tree --all --json)"
  self_path="$(script_path)"

  while IFS= read -r workspace_json; do
    [ -n "$workspace_json" ] || continue
    workspace_title="$(printf '%s\n' "$workspace_json" | jq -r '.title')"
    workspace_ref="$(printf '%s\n' "$current_tree" | jq -r --arg title "$workspace_title" '
      first(.windows[]?.workspaces[]? | select(.title == $title) | .ref) // empty
    ')"

    if [ -z "$workspace_ref" ]; then
      printf 'skipping workspace %s\n' "$workspace_title"
      continue
    fi

    while IFS= read -r entry_json; do
      [ -n "$entry_json" ] || continue
      pane_index="$(printf '%s\n' "$entry_json" | jq -r '.pane_index')"
      surface_index="$(printf '%s\n' "$entry_json" | jq -r '.surface_index_in_pane')"
      title="$(printf '%s\n' "$entry_json" | jq -r '.title')"
      session="$(printf '%s\n' "$entry_json" | jq -r '.session')"

      surface_ref="$(printf '%s\n' "$current_tree" | jq -r \
        --arg title "$workspace_title" \
        --argjson pane_index "$pane_index" \
        --argjson surface_index "$surface_index" '
          first(
            .windows[]?.workspaces[]?
            | select(.title == $title)
            | .panes[]?
            | select(.index == $pane_index)
            | .surfaces[]?
            | select(.type == "terminal" and .index_in_pane == $surface_index)
            | .ref
          ) // empty
        ')"

      if [ -z "$surface_ref" ]; then
        printf 'skipping tab %s in workspace %s\n' "$session" "$workspace_title"
        continue
      fi

      command_string="$(command_string_for_title "$self_path" "$title")"
      if cmux respawn-pane --workspace "$workspace_ref" --surface "$surface_ref" --command "$command_string" >/dev/null 2>&1; then
        printf 'restored %s: %s\n' "$workspace_title" "$session"
      else
        printf 'skipping restore for %s: %s\n' "$workspace_title" "$session"
      fi
    done <<EOF
$(printf '%s\n' "$workspace_json" | jq -c '.entries[]?')
EOF
  done <<EOF
$(jq -c '.workspaces[]?' "$state_file")
EOF
}

main() {
  case "${1:-}" in
    tab)
      shift
      cmd_tab "$@"
      ;;
    list)
      shift
      cmd_list "$@"
      ;;
    persist)
      shift
      cmd_persist "$@"
      ;;
    restore)
      shift
      cmd_restore "$@"
      ;;
    ""|-h|--help|help)
      usage
      ;;
    *)
      cmd_name "$@"
      ;;
  esac
}

main "$@"
